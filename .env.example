# Copy this file to `.env` and fill in real tokens. `.env` itself is
# gitignored -- never commit real tokens.

# Read-only token for the private dataset repo (avaeziaiteam/harakat-dataset
# account). Create one at https://huggingface.co/settings/tokens
HF_DATASET_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Write token for pushing trained checkpoints to the model repo. This is a
# DIFFERENT HF account from the dataset, so it needs its own token (with
# "Write" permission) from that account's settings.
HF_MODEL_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: the Makefile reads this too (via -include .env), so uncomment to
# persistently change the port `make train`/`make sweep` run TensorBoard on,
# instead of typing TB_PORT=... every time. Defaults to 6006 if unset.
TB_PORT=6006
